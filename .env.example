# Environment Selection
# Options: preprod, prod, staging
ENV=preprod

# Browser Configuration
# Options: chromium, firefox, webkit
BROWSER=chromium

# Headless Mode (true/false)
HEADLESS=false

# Slow Motion (milliseconds) - Slows down operations for visibility
SLOW_MO=500

# Default Timeout (milliseconds)
TIMEOUT=30000

# Screenshot on Failure (true/false)
SCREENSHOT_ON_FAILURE=true

# Video Recording on Failure (true/false)
VIDEO_ON_FAILURE=false

# Viewport Settings
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Parallel Execution Workers
PARALLEL_WORKERS=1

# Test Credentials
# Update these with your actual Abacus.ai credentials
VALID_USERNAME=your_username
VALID_PASSWORD=your_password
INVALID_USERNAME=invaliduser
INVALID_PASSWORD=wrongpass

# Report Directories
ALLURE_RESULTS_DIR=reports/allure-results
ALLURE_REPORT_DIR=reports/allure-report
SCREENSHOTS_DIR=screenshots
VIDEOS_DIR=videos
